{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reverie",
  "version": "0.3.0",
  "identifier": "com.animus.reverie",
  "build": {
    "beforeDevCommand": "npm --prefix ../.. run stage:bridge -- --profile debug && npm --prefix ../.. run dev:web",
    "beforeBuildCommand": "npm --prefix ../.. run build:web && npm --prefix ../.. run stage:bridge -- --profile release --triple aarch64-apple-darwin",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../web/dist"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/reverie-bridge",
      "binaries/reverie-bridge-preturn-hook",
      "binaries/reverie-codex-hook"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": ["frameworks/libghostty-vt.dylib"]
    }
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Reverie",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'none'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5RjQ2M0VBNjcwMjIxODYKUldTR0lRSm42bVAweVNxRUZ1RVhDL1YyTHVkcXB1U05VZmQzTm02cFMvT3ZkTmRrdE9GZWNuTTYK",
      "endpoints": ["https://github.com/Craigtut/reverie/releases/latest/download/latest.json"]
    }
  }
}
